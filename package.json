{
  "name": "tulia-study",
  "version": "0.2.2",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:web": "node scripts/generate-sitemap.mjs || true && mkdir -p out && rm -rf out/index.html out/assets out/registerSW.js out/sw.js out/workbox-*.js out/manifest.webmanifest && vite build",
    "generate-sitemap": "node scripts/generate-sitemap.mjs",
    "generate-static": "node scripts/generate-static-chapters.mjs",
    "preview": "vite preview",
    "sync-version": "node scripts/sync-version.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:android:build": "tauri android build && node scripts/rename-android-build.mjs",
    "deploy": "pnpm build:web && node scripts/generate-static-chapters.mjs && firebase deploy --only hosting",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hocuspocus/provider": "^2.15.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xyflow/react": "^12.10.2",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "dexie": "^4.4.2",
    "i18next": "^26.0.8",
    "laravel-echo": "^2.3.4",
    "lucide-react": "^0.441.0",
    "pusher-js": "^8.5.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.0",
    "yjs": "^13.6.30",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10",
    "happy-dom": "^20.9.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "typescript": "^5",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
